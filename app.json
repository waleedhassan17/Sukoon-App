{
  "expo": {
    "name": "Sukoon",
    "slug": "sukoon-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sukoon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D3B2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sukoon.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sukoon needs your location to find Qiblah direction and prayer times."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D3B2E"
      },
      "package": "com.sukoon.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.HIGH_SAMPLING_RATE_SENSORS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sensors",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
