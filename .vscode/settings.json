{
  "typescript.tsdk": "node_modules/typescript/lib",
  "java.home": "/usr/lib/jvm/java-17-openjdk-amd64",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-17",
      "path": "/usr/lib/jvm/java-17-openjdk-amd64",
      "default": true
    }
  ],
  "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G",
  "files.exclude": {
    "**/node_modules": true
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": ["**/node_modules"]
  },
  "json.schemas": [],
  "files.associations": {
    "**/node_modules/**/tsconfig.json": "plaintext"
  }
}
